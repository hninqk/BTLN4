<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="com.auction.controller.AuctionDetailController"
            stylesheets="@styles/main.css"
            styleClass="main-container">

    <left>
        <fx:include source="components/Sidebar.fxml" fx:id="sidebar"/>
    </left>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox styleClass="content-area" spacing="20" fillWidth="true">

                <!-- Back + header -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Button text="← Quay lại" onAction="#handleBack" styleClass="btn-secondary"/>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label fx:id="itemNameLabel" text="Chi tiết phiên đấu giá" styleClass="page-title"/>
                        <Label fx:id="auctionIdLabel" text="" styleClass="label-subtle"/>
                    </VBox>
                    <Label fx:id="statusBadge" text="..." styleClass="badge"/>
                </HBox>

                <!-- Main content: two columns -->
                <HBox spacing="20" fillHeight="true">

                    <!-- LEFT: Item details -->
                    <VBox spacing="16" HBox.hgrow="ALWAYS">

                        <VBox styleClass="card" spacing="10" alignment="CENTER">
                            <Label text="Ảnh sản phẩm" styleClass="section-title"/>
                            <Separator/>
                            <ImageView fx:id="itemImageView" fitWidth="420" fitHeight="250"
                                       preserveRatio="true" smooth="true"/>
                        </VBox>

                        <VBox styleClass="card" spacing="14">
                            <Label text="Thông tin sản phẩm" styleClass="section-title"/>
                            <Separator/>

                            <GridPane hgap="12" vgap="10">
                                <Label text="Tên sản phẩm:"  styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <Label fx:id="nameLabel"     text="" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                <Label text="Danh mục:"      styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <Label fx:id="categoryLabel" text="" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                <Label text="Người bán:"     styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                <Label fx:id="sellerLabel"   text="" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                                <Label text="Giá khởi điểm:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                                <Label fx:id="startPriceLabel" text="" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                                <Label text="Bắt đầu:"       styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                                <Label fx:id="startTimeLabel" text="" GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                                <Label text="Kết thúc:"      styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                                <Label fx:id="endTimeLabel"  text="" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                            </GridPane>
                        </VBox>

                        <VBox styleClass="card" spacing="10">
                            <Label text="Mô tả sản phẩm" styleClass="section-title"/>
                            <Separator/>
                            <Label fx:id="descriptionLabel" text="" wrapText="true"
                                   style="-fx-text-fill: #374151; -fx-font-size: 13px;"/>
                        </VBox>

                        <VBox styleClass="card" spacing="10">
                            <Label text="Thông tin thêm" styleClass="section-title"/>
                            <Separator/>
                            <Label fx:id="categoryInfoLabel" text="" styleClass="label-subtle" wrapText="true"/>
                        </VBox>

                    </VBox>

                    <!-- RIGHT: Bidding panel -->
                    <VBox spacing="16" prefWidth="320" minWidth="300">

                        <VBox styleClass="bid-panel" spacing="12" alignment="CENTER">
                            <Label text="Giá hiện tại" styleClass="stat-label"/>
                            <Label fx:id="currentPriceLabel" text="0 ₫" styleClass="bid-current-price"/>
                            <Label fx:id="bidCountLabel" text="0 lượt đấu giá" styleClass="label-subtle"/>
                            <Separator/>
                            <HBox alignment="CENTER" spacing="8">
                                <Label text="⏱ Còn lại:" styleClass="label-subtle"/>
                                <Label fx:id="timeRemainingLabel" text="--:--:--" styleClass="bid-timer"/>
                            </HBox>
                        </VBox>

                        <VBox styleClass="card" spacing="12">
                            <Label text="Tham gia đấu giá" styleClass="section-title"/>
                            <Separator/>
                            <Label text="Giá đặt của bạn (₫):" styleClass="form-label"/>
                            <TextField fx:id="bidAmountField" promptText="Nhập số tiền..."
                                       styleClass="text-field"/>
                            <Label fx:id="bidErrorLabel" text="" styleClass="label-error" wrapText="true"/>
                            <Button fx:id="placeBidButton" text="🔨 Đặt giá ngay"
                                    onAction="#handlePlaceBid"
                                    styleClass="btn-success" maxWidth="Infinity"/>
                            <Button text="📡 Xem trực tiếp" onAction="#handleGoToLive"
                                    styleClass="btn-primary" maxWidth="Infinity"/>
                        </VBox>

                        <!-- Winner info (shown when auction ends) -->
                        <VBox fx:id="winnerBox" styleClass="card" spacing="8"
                              style="-fx-background-color:#F0FDF4; -fx-border-color:#86EFAC;" visible="false" managed="false">
                            <Label text="🏆 Người thắng cuộc" styleClass="section-title"
                                   style="-fx-text-fill:#15803D;"/>
                            <Label fx:id="winnerLabel" text="" styleClass="label-subtle"/>
                            <Label fx:id="winnerPriceLabel" text="" style="-fx-font-weight:bold; -fx-text-fill:#15803D;"/>
                        </VBox>

                    </VBox>
                </HBox>

                <!-- Bid history table -->
                <VBox styleClass="card-no-padding" spacing="0">
                    <HBox style="-fx-padding: 14 20 10 20;">
                        <Label text="Lịch sử đặt giá" styleClass="section-title"/>
                    </HBox>
                    <Separator/>
                    <TableView fx:id="bidHistoryTable" prefHeight="200"
                               style="-fx-border-width:0; -fx-background-color:transparent;">
                        <columns>
                            <TableColumn fx:id="colBidder"  text="Người đấu giá"  prefWidth="180"/>
                            <TableColumn fx:id="colAmount"  text="Số tiền"        prefWidth="150"/>
                            <TableColumn fx:id="colBidTime" text="Thời gian"      prefWidth="200"/>
                        </columns>
                        <placeholder>
                            <Label text="Chưa có lượt đặt giá nào." styleClass="label-subtle"/>
                        </placeholder>
                    </TableView>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
