<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!-- Reusable sidebar component -->
<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:id="sidebarRoot"
      fx:controller="com.auction.controller.SidebarController"
      styleClass="sidebar"
      fillWidth="true">

    <!-- Brand header -->
    <VBox fx:id="brandBox" styleClass="sidebar-header" spacing="2">
        <Label fx:id="brandTitleLabel" text="AuctionSys" styleClass="sidebar-title"/>
        <Label fx:id="brandSubtitleLabel" text="Hệ thống Đấu giá" styleClass="sidebar-subtitle"/>
    </VBox>

    <!-- User info -->
    <VBox fx:id="userBox" styleClass="sidebar-user-box" spacing="2">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <javafx.scene.shape.SVGPath content="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5-4-8-4z" fill="#b0c4de" scaleX="1.2" scaleY="1.2"/>
            <VBox spacing="2">
                <Label fx:id="userNameLabel" text="..." styleClass="sidebar-subtitle"
                       style="-fx-text-fill: #E2E8F0; -fx-font-weight: bold; -fx-font-size: 14px;"/>
                <Label fx:id="userRoleLabel" text="..." styleClass="sidebar-subtitle"
                       style="-fx-text-fill: #8a9ba8; -fx-font-size: 12px;"/>
            </VBox>
        </HBox>
    </VBox>

    <!-- Navigation -->
    <Label fx:id="lblMain" text="CHÍNH" styleClass="sidebar-section-label"/>

    <Button fx:id="btnDashboard"  text="Tổng quan"
            onAction="#handleDashboard"  styleClass="nav-button" maxWidth="Infinity"/>
    <Button fx:id="btnAuctionList" text="Danh sách đấu giá"
            onAction="#handleAuctionList" styleClass="nav-button" maxWidth="Infinity"/>
    <Button fx:id="btnHistory"    text="Lịch sử đấu giá"
            onAction="#handleHistory"    styleClass="nav-button" maxWidth="Infinity"/>

    <Label fx:id="lblManagement" text="QUẢN LÝ" styleClass="sidebar-section-label"/>

    <Button fx:id="btnSeller"  text="Quản lý sản phẩm"
            onAction="#handleSeller"  styleClass="nav-button" maxWidth="Infinity"/>
    <Button fx:id="btnAdmin"   text="Quản trị hệ thống"
            onAction="#handleAdmin"   styleClass="nav-button" maxWidth="Infinity"/>

    <Label fx:id="lblAccount" text="TÀI KHOẢN" styleClass="sidebar-section-label"/>

    <Button fx:id="btnProfile" text="Hồ sơ cá nhân"
            onAction="#handleProfile" styleClass="nav-button" maxWidth="Infinity"/>
    <Button fx:id="btnSettings" text="Cài đặt"
            onAction="#handleSettings" styleClass="nav-button" maxWidth="Infinity"/>

    <Region VBox.vgrow="ALWAYS"/>

    <!-- Logout -->
    <Button fx:id="btnLogout" text="Đăng xuất" onAction="#handleLogout"
            styleClass="nav-button"
            style="-fx-text-fill: #F87171;"
            maxWidth="Infinity">
        <VBox.margin>
            <Insets bottom="8.0" />
        </VBox.margin>
    </Button>

</VBox>
