<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="com.auction.controller.HeaderController"
      styleClass="sticky-header"
      alignment="CENTER_LEFT"
      spacing="16"
      style="-fx-background-color: -theme-bg; -fx-border-color: -theme-border; -fx-border-width: 0 0 1 0; -fx-padding: 16 24;">

    <!-- Left: Title and Subtitle -->
    <VBox spacing="4" HBox.hgrow="ALWAYS">
        <Label fx:id="titleLabel" text="Tổng quan" styleClass="page-title"/>
        <Label fx:id="subtitleLabel" text="Chào mừng bạn trở lại!" styleClass="label-subtle"/>
    </VBox>

    <!-- Right: Notification Button (temporarily disabled) -->
    <StackPane>
        <Button fx:id="notificationButton" styleClass="btn-icon">
            <graphic>
                <StackPane>
                    <!-- Bell Icon -->
                    <javafx.scene.shape.SVGPath content="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.89 2 2 2zm6-6v-5c0-3.07-1.64-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.63 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z"
                                             style="-fx-fill: -theme-text;"
                                             scaleX="0.9"
                                             scaleY="0.9"/>

                    <!-- Badge for unread count -->
                    <StackPane fx:id="notificationBadge"
                               visible="false"
                               managed="false"
                               translateX="8"
                               translateY="-8"
                               style="-fx-background-color: #EF4444; -fx-background-radius: 10; -fx-min-width: 18; -fx-min-height: 18; -fx-max-width: 18; -fx-max-height: 18;">
                        <Label fx:id="badgeLabel"
                               text="0"
                               style="-fx-text-fill: white; -fx-font-size: 10px; -fx-font-weight: bold;"/>
                    </StackPane>
                </StackPane>
            </graphic>
        </Button>

        <!-- Notification Dropdown -->
        <VBox fx:id="notificationDropdown"
              visible="false"
              managed="false"
              styleClass="notification-dropdown"
              style="-fx-background-color: -theme-card-bg; -fx-background-radius: 8; -fx-border-color: -theme-border; -fx-border-width: 1; -fx-border-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 12, 0, 0, 4); -fx-padding: 8; -fx-pref-width: 380; -fx-max-height: 500;"
              translateX="-340"
              translateY="45">

            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding: 8 8 12 8;">
                <Label text="Thông báo" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: -theme-text;" HBox.hgrow="ALWAYS"/>
                <Button fx:id="markAllReadButton"
                        text="Đánh dấu tất cả đã đọc"
                        styleClass="btn-link"
                        style="-fx-font-size: 12px;"/>
            </HBox>

            <Separator style="-fx-background-color: -theme-border;"/>

            <!-- Notification List -->
            <ScrollPane fitToWidth="true"
                        vbarPolicy="AS_NEEDED"
                        hbarPolicy="NEVER"
                        styleClass="scroll-pane"
                        style="-fx-background-color: transparent; -fx-background: transparent;"
                        VBox.vgrow="ALWAYS">
                <VBox fx:id="notificationList" spacing="0" style="-fx-padding: 4;"/>
            </ScrollPane>
        </VBox>
    </StackPane>

</HBox>
