<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.scene.shape.SVGPath?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="com.auction.controller.AuctionDetailController"
            stylesheets="@styles/main.css"
            styleClass="main-container">

    <left>
        <fx:include source="components/Sidebar.fxml" fx:id="sidebar"/>
    </left>

    <center>
        <!-- Outer StackPane so chart-tooltip can float over everything -->
        <StackPane fx:id="rootStackPane" pickOnBounds="false">

            <!-- Aesthetic Geometric Background -->
            <Pane style="-fx-background-color: transparent;" mouseTransparent="true">
                <javafx.scene.shape.Circle radius="200" centerX="800" centerY="50" styleClass="geo-shape-1" />
                <javafx.scene.shape.Circle radius="300" centerX="150" centerY="600" styleClass="geo-shape-2" />
                <javafx.scene.shape.Polygon points="600,600, 800,400, 1000,600" styleClass="geo-shape-3" />
            </Pane>

            <!-- ScrollPane wrapper for responsive layout -->
            <ScrollPane fitToWidth="true" fitToHeight="false"
                        style="-fx-background-color: transparent; -fx-background: transparent;"
                        styleClass="scroll-pane">
                <VBox styleClass="content-area" spacing="12" fillWidth="true">

                    <!-- Desktop Header: Clock + Notification Bell -->
                    <fx:include source="components/DesktopHeader.fxml" fx:id="desktopHeader"/>

                <!-- ── Header ──────────────────────────────────────────── -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Button text="Quay lại" onAction="#handleBack" styleClass="btn-secondary">
                        <graphic>
                            <FontIcon iconLiteral="fas-arrow-left" iconSize="13" styleClass="button-icon"/>
                        </graphic>
                    </Button>
                    <VBox spacing="2" HBox.hgrow="ALWAYS">
                        <Label fx:id="itemNameLabel" text="Chi tiết phiên đấu giá" styleClass="page-title"/>
                        <Label fx:id="auctionIdLabel" text="" styleClass="label-subtle"/>
                    </VBox>
                    <Label fx:id="statusBadge" text="..." styleClass="badge"/>
                </HBox>

                <!-- ── Two-column body ─────────────────────────────────── -->
                <HBox spacing="14" fillHeight="true" VBox.vgrow="ALWAYS">

                    <!-- LEFT: Item info + chart -->
                    <VBox spacing="12" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS">

                        <!-- Item details card -->
                        <VBox styleClass="card" spacing="10">
                            <Label text="Thông tin sản phẩm" styleClass="section-title"/>
                            <Separator/>

                            <HBox spacing="16" alignment="CENTER_LEFT">
                                <GridPane hgap="12" vgap="8" HBox.hgrow="ALWAYS">
                                    <Label text="Tên sản phẩm:"   styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                    <Label fx:id="nameLabel"       text=""                 GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                                    <Label text="Danh mục:"       styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                    <Label fx:id="categoryLabel"   text=""                 GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                                    <Label text="Cửa hàng:"       styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                    <Label fx:id="sellerLabel"     text=""                 GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                                    <Label text="Giá khởi điểm:"  styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                                    <Label fx:id="startPriceLabel" text=""                 GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                                    <Label text="Bắt đầu:"        styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                                    <Label fx:id="startTimeLabel"  text="Chưa bắt đầu"    GridPane.columnIndex="1" GridPane.rowIndex="4"/>

                                    <Label text="Kết thúc:"       styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                                    <Label fx:id="endTimeLabel"    text=""                 GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                                </GridPane>

                                <ImageView fx:id="itemImageView" fitWidth="180" fitHeight="180"
                                           preserveRatio="true" smooth="true" HBox.hgrow="NEVER"/>
                            </HBox>

                            <Separator/>
                            <Label text="Mô tả sản phẩm:" styleClass="form-label"/>
                            <Label fx:id="descriptionLabel" text="" wrapText="true"
                                   style="-fx-text-fill: -theme-text; -fx-font-size: 13px;" maxHeight="60"/>
                        </VBox>

                        <!-- Price chart -->
                        <VBox styleClass="card" spacing="6" VBox.vgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="Biểu đồ giá đấu" styleClass="section-title" HBox.hgrow="ALWAYS">
                                    <graphic>
                                        <FontIcon iconLiteral="fas-chart-line" iconSize="14" styleClass="button-icon"/>
                                    </graphic>
                                </Label>
                            </HBox>
                            <Separator/>
                            <LineChart fx:id="priceChart" VBox.vgrow="ALWAYS" minHeight="160"
                                       createSymbols="true" legendVisible="false" animated="false">
                                <xAxis><NumberAxis fx:id="timeAxis" side="BOTTOM" forceZeroInRange="false" tickLabelRotation="0"/></xAxis>
                                <yAxis><NumberAxis side="LEFT"/></yAxis>
                            </LineChart>
                        </VBox>

                    </VBox>

                    <!-- RIGHT: Live bidding panel -->
                    <VBox spacing="12" prefWidth="370" minWidth="350" VBox.vgrow="ALWAYS">

                        <!-- Live price + timer -->
                        <VBox styleClass="bid-panel" spacing="8" alignment="CENTER">
                            <Label text="GIÁ HIỆN TẠI" styleClass="stat-label"/>
                            <Label fx:id="currentPriceLabel" text="0 ₫" styleClass="bid-current-price"/>
                            <Label fx:id="bidCountLabel" text="0 lượt đấu giá" styleClass="label-subtle"/>
                            <Separator/>
                            <HBox alignment="CENTER" spacing="8">
                                <Label text="Còn lại:" styleClass="label-subtle">
                                    <graphic>
                                        <FontIcon iconLiteral="fas-clock" iconSize="12" styleClass="button-icon"/>
                                    </graphic>
                                </Label>
                                <Label fx:id="timeRemainingLabel" text="--:--:--" styleClass="bid-timer"/>
                            </HBox>
                        </VBox>

                        <!-- Bid input card -->
                        <VBox styleClass="card" spacing="8">
                            <Label text="Tham gia đấu giá" styleClass="section-title"/>
                            <Separator/>
                            <Label text="Giá đặt của bạn (₫):" styleClass="form-label"/>
                            <TextField fx:id="bidAmountField" promptText="Nhập số tiền..."
                                       styleClass="text-field"/>
                            <Label fx:id="minBidHint" text="Tối thiểu: --" styleClass="label-subtle"/>
                            <Label fx:id="sellerWarningLabel" text="Bạn là seller, không được đấu giá!"
                                   style="-fx-text-fill: red; -fx-font-weight: bold;" managed="false" visible="false"/>
                            <Label fx:id="balanceLabel" text="" styleClass="label-subtle"
                                   style="-fx-text-fill: -theme-success-text; -fx-font-weight: bold;"/>
                            <Label fx:id="frozenLabel" text="" styleClass="label-subtle"
                                   style="-fx-text-fill: skyblue; -fx-font-weight: bold;"/>
                            <Label fx:id="bidErrorLabel" text="" styleClass="label-error" wrapText="true"/>

                            <!-- Bid button row: Place Bid + Auto-Bid toggle -->
                            <HBox spacing="8">
                                <Button fx:id="placeBidButton" text="Đặt giá ngay"
                                        onAction="#handlePlaceBid"
                                        graphicTextGap="6"
                                        style="-fx-background-color: #16A34A; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 9 12 9 12;"
                                        HBox.hgrow="ALWAYS" maxWidth="Infinity">
                                    <graphic>
                                        <Label text="&#x1f528;" style="-fx-text-fill: white; -fx-font-size: 13px;"/>
                                    </graphic>
                                </Button>
                                <Button fx:id="autoBidToggleButton" text="Đấu giá tự động"
                                        onAction="#handleToggleAutoBid"
                                        graphicTextGap="6"
                                        style="-fx-background-color: -theme-primary; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 9 12 9 12;"
                                        HBox.hgrow="ALWAYS" maxWidth="Infinity">
                                    <graphic>
                                        <Label text="&#x26a1;" style="-fx-text-fill: white; -fx-font-size: 13px;"/>
                                    </graphic>
                                </Button>
                            </HBox>
                            
                            <Label fx:id="currentAutoBidLabel" text="" styleClass="label-subtle"
                                   style="-fx-text-fill: -theme-primary; -fx-font-weight: bold;"
                                   managed="false" visible="false"/>
                        </VBox>

                        <!-- Winner box (shown after CLOSED) -->
                        <VBox fx:id="winnerBox" styleClass="card" spacing="8"
                              style="-fx-background-color: -theme-success-bg; -fx-border-color: -theme-success-border;"
                              visible="false" managed="false">
                            <Label text="Người thắng cuộc" styleClass="section-title"
                                   style="-fx-text-fill: -theme-success-text;">
                                <graphic>
                                    <SVGPath content="M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v3c0 2.44 1.72 4.48 4 4.88V18c0 1.66 1.34 3 3 3h4c1.66 0 3-1.34 3-3v-3.12c2.28-.4 4-2.44 4-4.88V7c0-1.1-.9-2-2-2zM5 10V7h2v3H5zm14 0h-2V7h2v3z" fill="#22C55E" style="-fx-fill: -theme-success-text;" scaleX="0.75" scaleY="0.75"/>
                                </graphic>
                            </Label>
                            <Label fx:id="winnerLabel"      text="" styleClass="label-subtle"/>
                            <Label fx:id="winnerPriceLabel" text=""
                                   style="-fx-font-weight:bold; -fx-text-fill: -theme-success-text;"/>
                        </VBox>

                        <!-- Live bid feed -->
                        <VBox styleClass="card" spacing="6" VBox.vgrow="ALWAYS">
                            <Label text="Nhật ký đấu giá" styleClass="section-title">
                                <graphic>
                                    <FontIcon iconLiteral="fas-broadcast-tower" iconSize="14" styleClass="button-icon"/>
                                </graphic>
                            </Label>
                            <Separator/>
                            <ListView fx:id="liveFeedList" VBox.vgrow="ALWAYS" minHeight="210"
                                      styleClass="list-view feed-list"/>
                        </VBox>

                    </VBox>
                </HBox>

            </VBox>
            </ScrollPane>

            <!-- ── Auto-Bid Popup Panel (floats, hidden by default) ── -->
            <VBox fx:id="autoBidPopup"
                  visible="false" managed="false"
                  style="-fx-background-color: -theme-surface; -fx-background-radius: 12; -fx-border-color: -theme-primary; -fx-border-radius: 12; -fx-border-width: 2;"
                  spacing="6" minWidth="320" prefWidth="340" maxWidth="360" maxHeight="-Infinity"
                  StackPane.alignment="CENTER">
                <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>

                <!-- Header: title + status badge + close button -->
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="Cấu hình Auto-Bid"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: -theme-primary;"
                           HBox.hgrow="ALWAYS" maxWidth="Infinity">
                        <graphic>
                            <FontIcon iconLiteral="fas-bolt" iconSize="13" styleClass="button-icon"/>
                        </graphic>
                    </Label>
                    <Label fx:id="autoBidStatusBadge" text="Chưa kích hoạt" styleClass="badge"
                           style="-fx-background-color: -theme-border; -fx-text-fill: -theme-text-muted; -fx-padding: 2 8;"/>
                    <Button text="X" onAction="#handleCloseAutoBidPopup"
                            style="-fx-background-color: #DC2626; -fx-text-fill: white; -fx-font-size: 11px; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 2 7 2 7; -fx-background-radius: 4;"
                            minWidth="28" minHeight="22"/>
                </HBox>

                <Separator/>


                <GridPane hgap="8" vgap="6">
                    <columnConstraints>
                        <ColumnConstraints minWidth="100" prefWidth="110" halignment="LEFT"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="80"/>
                    </columnConstraints>
                    <Label text="Giá tối đa (₫):" styleClass="form-label"
                           GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="autoMaxBidField" promptText="Ví dụ: 50,000,000"
                               styleClass="text-field"
                               GridPane.columnIndex="1" GridPane.rowIndex="0" GridPane.hgrow="ALWAYS"/>

                    <Label text="Bước giá (₫):" styleClass="form-label"
                           GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="autoIncrementField" promptText="Ví dụ: 100,000"
                               styleClass="text-field"
                               GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.hgrow="ALWAYS"/>
                </GridPane>

                <Label fx:id="autoBidErrorLabel" text="" styleClass="label-error" wrapText="true"/>
                <Button fx:id="registerAutoBidButton" text="Kích hoạt Auto-Bid"
                        onAction="#handleRegisterAutoBid"
                        style="-fx-background-color: -theme-primary; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 6 12;"
                        maxWidth="Infinity"/>
            </VBox>


        </StackPane>
    </center>

</BorderPane>
