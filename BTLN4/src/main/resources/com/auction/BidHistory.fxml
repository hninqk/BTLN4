<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="com.auction.controller.BidHistoryController"
            stylesheets="@styles/main.css"
            styleClass="main-container">

    <left>
        <fx:include source="components/Sidebar.fxml" fx:id="sidebar"/>
    </left>

    <center>
        <StackPane pickOnBounds="false">
            <!-- Aesthetic Geometric Background -->
            <Pane style="-fx-background-color: transparent;" mouseTransparent="true">
                <javafx.scene.shape.Circle radius="200" centerX="800" centerY="50" styleClass="geo-shape-1" />
                <javafx.scene.shape.Circle radius="300" centerX="150" centerY="600" styleClass="geo-shape-2" />
                <javafx.scene.shape.Polygon points="600,600, 800,400, 1000,600" styleClass="geo-shape-3" />
            </Pane>
            <VBox styleClass="content-area" style="-fx-background-color: transparent;" spacing="16" fillWidth="true">

            <!-- Desktop Header: Clock + Notification Bell -->
            <fx:include source="components/DesktopHeader.fxml" fx:id="desktopHeader"/>

            <!-- Summary stats -->
            <HBox spacing="16">
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8">
                    <Label text="Tổng lượt đặt giá" styleClass="stat-label"/>
                    <Label fx:id="totalBidsLabel" text="0" styleClass="stat-value"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8">
                    <Label text="Phiên đã thắng" styleClass="stat-label"/>
                    <Label fx:id="wonAuctionsLabel" text="0" styleClass="stat-value"
                           style="-fx-text-fill:#16A34A;"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8">
                    <Label text="Phiên đang tham gia" styleClass="stat-label"/>
                    <Label fx:id="activeParticipationsLabel" text="0" styleClass="stat-value"
                           style="-fx-text-fill:#2563EB;"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8">
                    <Label text="Tổng chi tiêu (thắng)" styleClass="stat-label"/>
                    <Label fx:id="totalSpentLabel" text="0 ₫" styleClass="stat-value"
                           style="-fx-font-size:20px; -fx-text-fill:#D97706;"/>
                </VBox>
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS" spacing="8">
                    <Label text="Số dư hiện tại" styleClass="stat-label"/>
                    <Label fx:id="currentBalanceLabel" text="0 ₫" styleClass="stat-value"
                           style="-fx-font-size:20px; -fx-text-fill:#10B981;"/>
                </VBox>
            </HBox>

            <!-- Filter bar -->
            <HBox spacing="8" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Tìm kiếm sản phẩm..."
                           styleClass="text-field" prefWidth="240" prefHeight="36"/>
                <ComboBox fx:id="resultFilter" promptText="Kết quả"
                          styleClass="combo-box" prefWidth="150" prefHeight="36"/>
                <Button fx:id="searchButton" text="Tìm" onAction="#handleSearch" styleClass="btn-secondary" prefHeight="36"/>
                <Button fx:id="resetButton" text="Đặt lại" onAction="#handleReset" styleClass="btn-secondary" prefHeight="36"/>
            </HBox>

            <!-- History table -->
            <TableView fx:id="historyTable" VBox.vgrow="ALWAYS"
                       style="-fx-border-width:0; -fx-background-color:transparent; -fx-padding: 0;"
                       onMouseClicked="#handleRowClick">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
                <columns>
                        <TableColumn fx:id="colItem"      text="Sản phẩm"       prefWidth="200"/>
                        <TableColumn fx:id="colSeller"    text="Người bán"      prefWidth="110"/>
                        <TableColumn fx:id="colMyBid"     text="Giá tôi đặt"   prefWidth="125"/>
                        <TableColumn fx:id="colFinalBid"  text="Giá chốt"      prefWidth="125"/>
                        <TableColumn fx:id="colResult"    text="Kết quả"        prefWidth="125"/>
                        <TableColumn fx:id="colStatus"    text="Trạng thái"    prefWidth="115"/>
                        <TableColumn fx:id="colBidTime"   text="Thời gian đặt" prefWidth="160"/>
                    </columns>
                    <placeholder>
                        <Label text="Bạn chưa tham gia phiên đấu giá nào." styleClass="label-subtle"/>
                    </placeholder>
                </TableView>

            <HBox alignment="CENTER_LEFT">
                <Label fx:id="statusLabel" text="" styleClass="label-subtle"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Xem chi tiết phiên" fx:id="viewDetailButton"
                        onAction="#handleViewDetail" styleClass="btn-link" visible="false"/>
            </HBox>

            <HBox fx:id="paginationBox" alignment="CENTER" spacing="6" styleClass="pagination-bar"/>

        </VBox>
        </StackPane>
    </center>

</BorderPane>
