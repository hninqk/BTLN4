<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="com.auction.controller.SettingsController"
            stylesheets="@styles/main.css"
            styleClass="main-container">

    <left>
        <fx:include source="components/Sidebar.fxml" fx:id="sidebar"/>
    </left>

    <center>
        <VBox styleClass="content-area" spacing="20" fillWidth="true">
            <Label text="Cài đặt hệ thống" styleClass="page-title"/>

            <VBox styleClass="card" spacing="16" maxWidth="600">
                <Label text="Giao diện &amp; Hiển thị" styleClass="section-title"/>
                <Separator/>
                <HBox alignment="CENTER_LEFT" spacing="20">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Chế độ tối (Dark Mode)" styleClass="form-label"/>
                        <Label text="Chuyển đổi giao diện sang nền tối để bảo vệ mắt." styleClass="label-subtle"/>
                    </VBox>
                    <ToggleButton fx:id="btnDarkModeToggle" text="Bật / Tắt" onAction="#handleToggleDarkMode" styleClass="btn-secondary"/>
                </HBox>
            </VBox>
        </VBox>
    </center>

</BorderPane>
