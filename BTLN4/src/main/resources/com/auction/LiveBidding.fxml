<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="com.auction.controller.LiveBiddingController"
            stylesheets="@styles/main.css"
            styleClass="main-container">

    <left>
        <fx:include source="components/Sidebar.fxml" fx:id="sidebar"/>
    </left>

    <center>
        <VBox styleClass="content-area" spacing="20">
            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="15">
                <Button text="← Quay lại" onAction="#handleBack" styleClass="btn-secondary"/>
                <VBox HBox.hgrow="ALWAYS">
                    <Label fx:id="auctionTitleLabel" text="Tên sản phẩm..." styleClass="page-title"/>
                    <Label fx:id="auctionSubtitleLabel" text="Thông tin phiên đấu..." styleClass="label-subtle"/>
                </VBox>
            </HBox>

            <HBox spacing="20" VBox.vgrow="ALWAYS">
                <VBox spacing="20" HBox.hgrow="ALWAYS">
                    <HBox spacing="20" styleClass="card" alignment="CENTER">
                        <ImageView fx:id="itemImageView" fitWidth="300" fitHeight="200" preserveRatio="true"/>
                        <VBox spacing="10" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                            <Label text="GIÁ HIỆN TẠI" styleClass="stat-label"/>
                            <Label fx:id="livePriceLabel" text="0 ₫" styleClass="bid-current-price" style="-fx-font-size: 32px;"/>
                            <Separator/>
                            <HBox spacing="20">
                                <VBox>
                                    <Label text="THỜI GIAN" styleClass="stat-label"/>
                                    <Label fx:id="liveTimerLabel" text="00:00:00" styleClass="bid-timer"/>
                                </VBox>
                                <VBox>
                                    <Label text="LƯỢT ĐẶT" styleClass="stat-label"/>
                                    <Label fx:id="bidCountLabel" text="0" styleClass="stat-value"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </HBox>

                    <VBox styleClass="card" VBox.vgrow="ALWAYS">
                        <Label text="Biểu đồ lịch sử giá" styleClass="section-title"/>
                        <LineChart fx:id="priceChart" createSymbols="true" legendVisible="false" VBox.vgrow="ALWAYS">
                            <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                            <yAxis><NumberAxis side="LEFT" /></yAxis>
                        </LineChart>
                    </VBox>
                </VBox>

                <VBox spacing="20" prefWidth="350">
                    <VBox styleClass="card" spacing="15">
                        <Label text="Đặt giá mới" styleClass="section-title"/>
                        <TextField fx:id="bidAmountField" promptText="Nhập số tiền (₫)..." style="-fx-font-size: 16px;"/>
                        <Label fx:id="minBidHint" text="Giá tối thiểu: --" styleClass="label-subtle"/>
                        <Label fx:id="bidErrorLabel" text="" styleClass="label-error" wrapText="true"/>
                        <Button fx:id="placeBidButton" text="ĐẶT GIÁ NGAY" onAction="#handlePlaceBid"
                                maxWidth="Infinity" styleClass="btn-success" style="-fx-font-weight: bold;"/>
                    </VBox>

                    <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="10">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Lịch sử đấu giá" styleClass="section-title"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lastUpdateLabel" text="--" styleClass="label-subtle"/>
                        </HBox>
                        <ListView fx:id="liveFeedList" VBox.vgrow="ALWAYS" styleClass="live-feed-list"/>
                    </VBox>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>