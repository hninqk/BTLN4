<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="com.auction.controller.UserProfileController"
            stylesheets="@styles/main.css"
            styleClass="main-container">

    <left>
        <fx:include source="components/Sidebar.fxml" fx:id="sidebar"/>
    </left>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox styleClass="content-area" spacing="20" fillWidth="true">

                <Label text="Hồ sơ cá nhân" styleClass="page-title"/>

                <HBox spacing="24" fillHeight="true">

                    <VBox spacing="16" prefWidth="380" minWidth="340">

                        <VBox styleClass="card" spacing="14" alignment="CENTER">
                            <Label fx:id="avatarLabel" text="👤" style="-fx-font-size:56px;"/>
                            <VBox alignment="CENTER" spacing="6">
                                <Label fx:id="displayNameLabel" text="..."
                                       style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:-theme-text;"/>
                                <Label fx:id="roleLabel" text="..." styleClass="badge badge-open"/>
                            </VBox>
                            <Label fx:id="memberSinceLabel" text="" styleClass="label-subtle"/>
                        </VBox>

                        <VBox fx:id="bidderStatsBox" styleClass="card" spacing="12">
                            <Label text="Thống kê hoạt động" styleClass="section-title"/>
                            <Separator/>
                            <HBox spacing="12">
                                <VBox HBox.hgrow="ALWAYS" alignment="CENTER" styleClass="stat-card" spacing="6">
                                    <Label text="Số dư hiện tại" styleClass="stat-label"/>
                                    <Label fx:id="balanceLabel" text="0 ₫"
                                           style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:#16A34A;"/>
                                </VBox>
                                <VBox HBox.hgrow="ALWAYS" alignment="CENTER" styleClass="stat-card" spacing="6">
                                    <Label text="Lượt đặt giá" styleClass="stat-label"/>
                                    <Label fx:id="totalBidsLabel" text="0"
                                           style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:-theme-text;"/>
                                </VBox>
                            </HBox>
                        </VBox>

                        <VBox fx:id="sellerStatsBox" styleClass="card" spacing="12" visible="false" managed="false">
                            <Label text="Thông tin cửa hàng" styleClass="section-title"/>
                            <Separator/>
                            <GridPane hgap="12" vgap="10">
                                <Label text="Tên cửa hàng:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <Label fx:id="shopNameLabel" text="" style="-fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                
                                <Label text="Phiên đã tạo:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <Label fx:id="auctionCountLabel" text="" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                            </GridPane>
                        </VBox>

                    </VBox>

                    <VBox spacing="16" HBox.hgrow="ALWAYS">
                        
                        <VBox spacing="4">
                            <Label fx:id="profileErrorLabel" text="" styleClass="label-error" wrapText="true"/>
                            <Label fx:id="profileSuccessLabel" text="" styleClass="label-success" wrapText="true"/>
                        </VBox>

                        <VBox fx:id="balanceBox" styleClass="card" spacing="14" visible="false" managed="false">
                            <Label text="Quản lý số dư" styleClass="section-title"/>
                            <Separator/>
                            <VBox spacing="8">
                                <Label text="Nạp tiền vào tài khoản (₫)" styleClass="form-label"/>
                                <HBox spacing="10">
                                    <TextField fx:id="depositField" promptText="VD: 500000"
                                               styleClass="text-field" HBox.hgrow="ALWAYS"/>
                                    <Button text="💳 Nạp ngay" onAction="#handleDeposit" styleClass="btn-success"/>
                                </HBox>
                            </VBox>
                        </VBox>

                        <VBox fx:id="shopNameBox" styleClass="card" spacing="14" visible="false" managed="false">
                            <Label text="Cài đặt cửa hàng" styleClass="section-title"/>
                            <Separator/>
                            <VBox spacing="8">
                                <Label text="Tên cửa hàng" styleClass="form-label"/>
                                <HBox spacing="10">
                                    <TextField fx:id="shopNameField" promptText="Nhập tên cửa hàng mới..." 
                                               styleClass="text-field" HBox.hgrow="ALWAYS"/>
                                    <Button text="💾 Cập nhật" onAction="#handleSaveProfile" styleClass="btn-primary"/>
                                </HBox>
                            </VBox>
                        </VBox>

                    </VBox>

                </HBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>