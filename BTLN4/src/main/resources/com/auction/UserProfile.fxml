<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="com.auction.ui.controller.UserProfileController"
            stylesheets="@styles/main.css"
            styleClass="main-container">

    <left>
        <fx:include source="components/Sidebar.fxml" fx:id="sidebar"/>
    </left>

    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-pane">
            <VBox styleClass="content-area" spacing="20" fillWidth="true">

                <!-- Desktop Header: Clock + Notification Bell -->
                <fx:include source="components/DesktopHeader.fxml" fx:id="desktopHeader"/>

                <!-- ══ TOP: Avatar card (User Profile) + Thông tin cửa hàng — side-by-side ══ -->
                <HBox spacing="20" alignment="TOP_LEFT">

                    <!-- ① User Profile Card (Avatar) -->
                    <VBox styleClass="card" spacing="14" alignment="CENTER"
                          prefWidth="260" minWidth="220" prefHeight="220">
                        <Label fx:id="avatarLabel" text="👤" style="-fx-font-size:56px;"/>
                        <VBox alignment="CENTER" spacing="6">
                            <Label fx:id="displayNameLabel" text="..."
                                   style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:-theme-text;"/>
                            <Label fx:id="roleLabel" text="..." styleClass="badge badge-open"/>
                        </VBox>
                        <Label fx:id="memberSinceLabel" text="" styleClass="label-subtle"/>
                    </VBox>

                    <!-- ② Seller: Thông tin cửa hàng — parallel to Avatar card -->
                    <VBox fx:id="sellerStatsBox" styleClass="card" spacing="12"
                          visible="false" managed="false"
                          HBox.hgrow="ALWAYS" prefHeight="220">
                        <Label text="Thông tin cửa hàng" styleClass="section-title"/>
                        <Separator/>
                        <GridPane hgap="15" vgap="12">
                            <Label text="Tên cửa hàng:" styleClass="form-label" style="-fx-font-size: 14px;"
                                   GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                            <Label fx:id="shopNameLabel" text=""
                                   style="-fx-font-weight: bold; -fx-font-size: 14px;"
                                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                            <Label text="Phiên đã tạo:" styleClass="form-label" style="-fx-font-size: 14px;"
                                   GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                            <Label fx:id="auctionCountLabel" text="" style="-fx-font-size: 14px;"
                                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                            <Label text="Phiên đã chốt:" styleClass="form-label" style="-fx-font-size: 14px;"
                                   GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                            <Label fx:id="closedAuctionCountLabel" text="" style="-fx-font-size: 14px;"
                                   GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                            <Label text="Tổng doanh thu:" styleClass="form-label" style="-fx-font-size: 14px;"
                                   GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                            <Label fx:id="totalRevenueLabel" text=""
                                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #16A34A;"
                                   GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                        </GridPane>
                    </VBox>

                    <!-- ② Bidder: activity stats — shown instead of sellerStatsBox for bidders -->
                    <VBox fx:id="bidderStatsBox" styleClass="card" spacing="12"
                          visible="false" managed="false"
                          HBox.hgrow="ALWAYS" prefHeight="220">
                        <Label text="Thống kê hoạt động" styleClass="section-title"/>
                        <Separator/>
                        <HBox spacing="12">
                            <VBox HBox.hgrow="ALWAYS" alignment="CENTER"
                                  styleClass="stat-card" spacing="6">
                                <Label text="Số dư hiện tại" styleClass="stat-label"/>
                                <Label fx:id="balanceLabel" text="0 ₫"
                                       style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:#16A34A;"/>
                            </VBox>
                            <VBox HBox.hgrow="ALWAYS" alignment="CENTER"
                                  styleClass="stat-card" spacing="6">
                                <Label text="Lượt đặt giá" styleClass="stat-label"/>
                                <Label fx:id="totalBidsLabel" text="0"
                                       style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:-theme-text;"/>
                            </VBox>
                        </HBox>
                    </VBox>

                </HBox>

                <!-- Feedback labels (below top cards) -->
                <VBox spacing="4">
                    <Label fx:id="profileErrorLabel"   text="" styleClass="label-error"   wrapText="true"/>
                    <Label fx:id="profileSuccessLabel" text="" styleClass="label-success" wrapText="true"/>
                </VBox>

                <!-- Bidder: balance deposit (below top cards) -->
                <VBox fx:id="balanceBox" styleClass="card" spacing="14"
                      visible="false" managed="false">
                    <Label text="Quản lý số dư" styleClass="section-title"/>
                    <Separator/>
                    <VBox spacing="8">
                        <Label text="Nạp tiền vào tài khoản (₫)" styleClass="form-label"/>
                        <HBox spacing="10">
                            <TextField fx:id="depositField" promptText="VD: 500000"
                                       styleClass="text-field" HBox.hgrow="ALWAYS"/>
                            <Button text="💳 Nạp ngay" onAction="#handleDeposit"
                                    styleClass="btn-success"/>
                        </HBox>
                    </VBox>
                </VBox>

                <!-- ══ BOTTOM: Removed Seller Activity Panel (migrated to dashboard) ════════════════ -->

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>