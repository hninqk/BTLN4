<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.PieChart?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="com.auction.controller.DashboardController"
            stylesheets="@styles/main.css"
            styleClass="main-container">

    <!-- LEFT: Sidebar -->
    <left>
        <fx:include source="components/Sidebar.fxml" fx:id="sidebar"/>
    </left>

    <!-- CENTER: Content -->
    <center>
        <StackPane pickOnBounds="false">
            <Pane style="-fx-background-color: transparent;" mouseTransparent="true" />

            <VBox styleClass="content-area" style="-fx-background-color: transparent;" spacing="20" fillWidth="true">

                <!-- Header & Search -->
                <HBox alignment="CENTER_LEFT" spacing="16">
                    <VBox spacing="4">
                        <Label text="Tổng quan" styleClass="page-title"/>
                        <Label fx:id="welcomeLabel" text="Chào mừng bạn trở lại!" styleClass="label-subtle"/>
                    </VBox>
                </HBox>

                <!-- Seller View -->
                <VBox fx:id="sellerView" visible="false" managed="false" spacing="20" fillWidth="true">
                    <HBox spacing="24" alignment="TOP_CENTER" VBox.vgrow="ALWAYS">
                        <!-- CARD 1: Stats & Heatmap Container (left) -->
                        <VBox styleClass="stat-card-navy" HBox.hgrow="ALWAYS" maxWidth="Infinity" VBox.vgrow="ALWAYS" spacing="12" alignment="TOP_LEFT">
                            <Label text="Hoạt động &amp; Thống kê" styleClass="section-title"/>
                            <HBox spacing="12" HBox.hgrow="ALWAYS" alignment="TOP_LEFT">
                                <!-- Left half: 3 stat lines --> 
                                <VBox spacing="12" HBox.hgrow="ALWAYS" alignment="TOP_LEFT">
                                    <Label text="Tổng doanh thu" styleClass="stat-card-navy-title"/>
                                    <Label fx:id="sellerEarningLabel" text="0 ₫" styleClass="stat-card-navy-value"/>

                                    <Label text="Doanh thu 30 ngày" styleClass="stat-card-navy-title"/>
                                    <Label fx:id="sellerRevenueLabel" text="0 ₫" styleClass="stat-card-navy-value"/>

                                    <Label text="Phiên đã chốt" styleClass="stat-card-navy-title"/>
                                    <Label fx:id="sellerClosedLabel" text="0" styleClass="stat-card-navy-value"/>
                                </VBox>

                                <!-- Right half: heatmap title + grid together --> 
                                <VBox spacing="8" HBox.hgrow="ALWAYS" alignment="TOP_LEFT">
                                    <Label text="Doanh thu 35 ngày gần nhất" styleClass="section-title"/>
                                    <GridPane fx:id="sellerRevenueHeatmap" hgap="3" vgap="3" alignment="TOP_LEFT">
                                        <Label text="Sun" styleClass="heatmap-day-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                        <Label text="Mon" styleClass="heatmap-day-label" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                        <Label text="Tue" styleClass="heatmap-day-label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                                        <Label text="Wed" styleClass="heatmap-day-label" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                                        <Label text="Thu" styleClass="heatmap-day-label" GridPane.columnIndex="4" GridPane.rowIndex="0"/>
                                        <Label text="Fri" styleClass="heatmap-day-label" GridPane.columnIndex="5" GridPane.rowIndex="0"/>
                                        <Label text="Sat" styleClass="heatmap-day-label" GridPane.columnIndex="6" GridPane.rowIndex="0"/>
                                    </GridPane>
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- CARD 2: Pie Chart (right) -->
                        <VBox styleClass="stat-card-navy" HBox.hgrow="ALWAYS" maxWidth="Infinity" VBox.vgrow="ALWAYS" spacing="12" alignment="TOP_CENTER">
                            <Label text="Phân bố danh mục sản phẩm" styleClass="section-title"/>
                            <StackPane VBox.vgrow="ALWAYS" alignment="CENTER">
                                <PieChart fx:id="sellerCategoryPieChart" legendVisible="false"/>
                            </StackPane>
                            <FlowPane fx:id="sellerPieLegend" hgap="10" vgap="6" alignment="CENTER"/>
                        </VBox>
                    </HBox>
                </VBox>

            </VBox>
        </StackPane>
    </center>

</BorderPane>
