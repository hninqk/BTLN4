<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="com.auction.controller.DashboardController"
            stylesheets="@styles/main.css"
            styleClass="main-container">

    <!-- LEFT: Sidebar -->
    <left>
        <fx:include source="components/Sidebar.fxml" fx:id="sidebar"/>
    </left>

    <!-- CENTER: Content -->
    <center>
        <StackPane pickOnBounds="false">
            <!-- Aesthetic Geometric Background -->
            <Pane style="-fx-background-color: transparent;" mouseTransparent="true">
                <javafx.scene.shape.Circle radius="200" centerX="800" centerY="50" styleClass="geo-shape-1" />
                <javafx.scene.shape.Circle radius="300" centerX="150" centerY="600" styleClass="geo-shape-2" />
                <javafx.scene.shape.Polygon points="600,600, 800,400, 1000,600" styleClass="geo-shape-3" />
            </Pane>

            <VBox styleClass="content-area" style="-fx-background-color: transparent;" spacing="20" fillWidth="true">

            <!-- Header & Search -->
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="4">
                    <Label text="Tổng quan" styleClass="page-title"/>
                    <Label fx:id="welcomeLabel" text="Chào mừng bạn trở lại!" styleClass="label-subtle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="🚀 Khám phá Đấu giá" onAction="#handleViewAllAuctions" styleClass="btn-primary" style="-fx-font-size: 14px; -fx-padding: 10 24;"/>
            </HBox>

            <!-- News Banner -->
            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: #EFF6FF; -fx-padding: 14 20; -fx-background-radius: 8; -fx-border-color: #BFDBFE; -fx-border-radius: 8;">
                <Label text="📢 TIN NÓNG:" style="-fx-text-fill: #1D4ED8; -fx-font-weight: bold;"/>
                <Label text="Tuần lễ vàng đấu giá siêu xe và nghệ thuật đương đại đang diễn ra. Đừng bỏ lỡ!" style="-fx-text-fill: #1E3A8A;"/>
            </HBox>

            <!-- Stat cards row -->
            <HBox spacing="12" fillHeight="false">
                <!-- Card 1 -->
                <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="Đang diễn ra" styleClass="stat-label"/>
                    <Label fx:id="activeAuctionsLabel" text="0" styleClass="stat-value"/>
                    <Label text="🔴 RUNNING" styleClass="label-subtle"/>
                </VBox>
                <!-- Card 2 -->
                <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="Chờ bắt đầu" styleClass="stat-label"/>
                    <Label fx:id="openAuctionsLabel" text="0" styleClass="stat-value"/>
                    <Label text="🟢 OPEN" styleClass="label-subtle"/>
                </VBox>
                <!-- Card 3 -->
                <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="Chờ duyệt" styleClass="stat-label"/>
                    <Label fx:id="pendingAuctionsLabel" text="0" styleClass="stat-value"/>
                    <Label text="⏳ PENDING" styleClass="label-subtle"/>
                </VBox>
                <!-- Card 4 -->
                <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="Tổng phiên" styleClass="stat-label"/>
                    <Label fx:id="totalAuctionsLabel" text="0" styleClass="stat-value"/>
                    <Label text="Tất cả trạng thái" styleClass="label-subtle"/>
                </VBox>
                <!-- Card 5 -->
                <VBox styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="Người dùng" styleClass="stat-label"/>
                    <Label fx:id="totalUsersLabel" text="0" styleClass="stat-value"/>
                    <Label text="Bidder + Seller + Admin" styleClass="label-subtle"/>
                </VBox>
            </HBox>

            <!-- Hot Items Showcase -->
            <VBox spacing="12" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT">
                    <Label text="🔥 Top Sản phẩm Nổi bật" styleClass="section-title"/>
                </HBox>
                <ScrollPane fitToHeight="true" fitToWidth="true" vbarPolicy="NEVER" styleClass="scroll-pane" style="-fx-background-color: transparent;">
                    <HBox fx:id="hotItemsBox" spacing="20" style="-fx-padding: 8 4 16 4;"/>
                </ScrollPane>
            </VBox>

        </VBox>
        </StackPane>
    </center>

</BorderPane>
