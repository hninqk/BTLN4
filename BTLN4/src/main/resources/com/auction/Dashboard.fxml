<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.PieChart?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="com.auction.controller.DashboardController"
            stylesheets="@styles/main.css"
            styleClass="main-container">

    <!-- LEFT: Sidebar -->
    <left>
        <fx:include source="components/Sidebar.fxml" fx:id="sidebar"/>
    </left>

    <!-- CENTER: Content -->
    <center>
        <StackPane pickOnBounds="false">
            <Pane style="-fx-background-color: transparent;" mouseTransparent="true" />

            <ScrollPane fitToWidth="true" fitToHeight="true" vbarPolicy="AS_NEEDED" hbarPolicy="NEVER"
                        styleClass="scroll-pane" style="-fx-background-color: transparent; -fx-background: transparent;">
                <VBox styleClass="content-area" style="-fx-background-color: transparent;" spacing="20" fillWidth="true">

                    <!-- Header & Search -->
                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <VBox spacing="4">
                            <Label text="Tổng quan" styleClass="page-title"/>
                            <Label fx:id="welcomeLabel" text="Chào mừng bạn trở lại!" styleClass="label-subtle"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="exploreButton" text="🚀 Khám phá Đấu giá" onAction="#handleViewAllAuctions" styleClass="btn-primary" style="-fx-font-size: 14px; -fx-padding: 10 24;"/>
                    </HBox>

                    <!-- Bidder View -->
                    <VBox fx:id="bidderView" visible="false" managed="false" spacing="20" fillWidth="true">
                        <!-- News Banner -->
                        <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: -theme-bid-panel; -fx-padding: 14 20; -fx-background-radius: 8; -fx-border-color: -theme-bid-border; -fx-border-radius: 8;">
                            <Label text="📢 TIN NÓNG:" style="-fx-text-fill: -theme-primary; -fx-font-weight: bold;"/>
                            <Label fx:id="newsLabel" text="Tuần lễ vàng đấu giá siêu xe và nghệ thuật đương đại đang diễn ra. Đừng bỏ lỡ!" style="-fx-text-fill: -theme-text;"/>
                        </HBox>

                        <!-- Stat cards row (role-based visibility set by controller) -->
                        <HBox spacing="12" fillHeight="true">
                            <!-- Card 1 -->
                            <VBox fx:id="cardRunning" styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                                <Label text="Đang diễn ra" styleClass="stat-label"/>
                                <Label fx:id="dashStatRunning" text="0" styleClass="stat-value"/>
                                <Label text=" RUNNING" styleClass="label-subtle" style="-fx-text-fill: #22C55E;">
                                    <graphic>
                                        <javafx.scene.shape.Circle radius="5" fill="#22C55E"/>
                                    </graphic>
                                </Label>
                            </VBox>
                            <!-- Card 2 -->
                            <VBox fx:id="cardOpen" styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                                <Label text="Chờ bắt đầu" styleClass="stat-label"/>
                                <Label fx:id="dashStatOpen" text="0" styleClass="stat-value"/>
                                <Label text=" OPEN" styleClass="label-subtle" style="-fx-text-fill: #3B82F6;">
                                    <graphic>
                                        <javafx.scene.shape.SVGPath content="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z" fill="#3B82F6" scaleX="0.75" scaleY="0.75"/>
                                    </graphic>
                                </Label>
                            </VBox>
                            <!-- Card 3 (Admin only) -->
                            <VBox fx:id="cardPending" styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                                <Label text="Chờ duyệt" styleClass="stat-label"/>
                                <Label fx:id="dashStatPending" text="0" styleClass="stat-value"/>
                                <Label text=" PENDING" styleClass="label-subtle" style="-fx-text-fill: #F59E0B;">
                                    <graphic>
                                        <javafx.scene.shape.SVGPath content="M6 2v6h.01L6 8.01 10 12l-4 4 .01.01H6V22h12v-5.99h-.01L18 16l-4-4 4-3.99-.01-.01H18V2H6zm10 14.5V20H8v-3.5l4-4 4 4zm-4-5l-4-4V4h8v3.5l-4 4z" fill="#F59E0B" scaleX="0.65" scaleY="0.65"/>
                                    </graphic>
                                </Label>
                            </VBox>
                            <!-- Card 4 (Admin only) -->
                            <VBox fx:id="cardTotalAuctions" styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                                <Label text="Tổng phiên" styleClass="stat-label"/>
                                <Label fx:id="dashStatTotalAuctions" text="0" styleClass="stat-value"/>
                                <Label text=" Tất cả trạng thái" styleClass="label-subtle" style="-fx-text-fill: #8B5CF6;">
                                    <graphic>
                                        <javafx.scene.shape.SVGPath content="M11.99 18.54l-7.37-5.73L3 14.07l9 7 9-7-1.63-1.27zM12 16l7.36-5.73L21 9l-9-7-9 7 1.63 1.27L12 16zm0-11.47L17.74 9 12 13.47 6.26 9 12 4.53z" fill="#8B5CF6" scaleX="0.7" scaleY="0.7"/>
                                    </graphic>
                                </Label>
                            </VBox>
                            <!-- Card 5 (Admin only) -->
                            <VBox fx:id="cardTotalUsers" styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                                <Label text="Người dùng" styleClass="stat-label"/>
                                <Label fx:id="dashStatTotalUsers" text="0" styleClass="stat-value"/>
                                <Label text=" Bidder + Seller + Admin" styleClass="label-subtle" style="-fx-text-fill: #06B6D4;">
                                    <graphic>
                                        <javafx.scene.shape.SVGPath content="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z" fill="#06B6D4" scaleX="0.75" scaleY="0.75"/>
                                    </graphic>
                                </Label>
                            </VBox>
                        </HBox>

                        <!-- Hot Items Showcase -->
                        <VBox spacing="12" VBox.vgrow="ALWAYS">
                            <Label text=" Top Sản phẩm Nổi bật" styleClass="section-title">
                                <graphic>
                                    <javafx.scene.shape.SVGPath content="M17.66 11.2c-.23-.3-.51-.56-.77-.82-.67-.6-1.43-1.03-2.07-1.66C13.33 7.26 13 4.85 13.95 3c-.95.23-1.78.75-2.49 1.32-2.59 2.08-3.61 5.75-2.39 8.9.04.1.08.2.08.33 0 .22-.15.42-.35.5-.22.1-.46.04-.64-.12a6.35 6.35 0 0 1-1.68-2.19c-.5-1.13-.53-2.39-.23-3.56C4.1 10.15 3 13.62 3.65 16.71c.54 2.58 2.34 4.8 4.78 5.74 2.82 1.09 6.27.53 8.44-1.6 2.39-2.34 2.94-6.07.79-9.65zm-4.7 7.02c-1.34 1.15-3.32 1.16-4.4-.13-.26-.31-.47-.65-.63-1.02.5.47 1.19.78 1.93.78 1.54 0 2.8-1.25 2.8-2.8 0-.46-.11-.9-.31-1.28.67.62 1.18 1.48 1.36 2.45.1.53-.02 1.09-.35 1.5l-.4.5z" fill="#F97316" scaleX="0.8" scaleY="0.8"/>
                                </graphic>
                            </Label>
                            <ScrollPane fitToWidth="true" vbarPolicy="AS_NEEDED" hbarPolicy="NEVER" styleClass="scroll-pane" style="-fx-background-color: transparent;">
                                <FlowPane fx:id="hotItemsBox" hgap="20" vgap="20" style="-fx-padding: 8 4 16 4;"/>
                            </ScrollPane>
                        </VBox>
                    </VBox>

                    <!-- Seller View -->
                    <VBox fx:id="sellerView" visible="false" managed="false" spacing="20" fillWidth="true">
                        <!-- News Banner -->
                        <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: -theme-bid-panel; -fx-padding: 14 20; -fx-background-radius: 8; -fx-border-color: -theme-bid-border; -fx-border-radius: 8;">
                            <Label text="📢 TIN NÓNG:" style="-fx-text-fill: -theme-primary; -fx-font-weight: bold;"/>
                            <Label fx:id="sellerNewsLabel" text="Tuần lễ vàng đấu giá siêu xe và nghệ thuật đương đại đang diễn ra. Đừng bỏ lỡ!" style="-fx-text-fill: -theme-text;"/>
                        </HBox>

                        <!-- Stat cards row (role-based visibility set by controller) -->
                        <HBox spacing="12" fillHeight="true">
                            <VBox fx:id="sellerCardRunning" styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                                <Label text="Đang diễn ra" styleClass="stat-label"/>
                                <Label fx:id="sellerDashStatRunning" text="0" styleClass="stat-value"/>
                                <Label text=" RUNNING" styleClass="label-subtle" style="-fx-text-fill: #22C55E;">
                                    <graphic>
                                        <javafx.scene.shape.Circle radius="5" fill="#22C55E"/>
                                    </graphic>
                                </Label>
                            </VBox>
                            <VBox fx:id="sellerCardOpen" styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                                <Label text="Chờ bắt đầu" styleClass="stat-label"/>
                                <Label fx:id="sellerDashStatOpen" text="0" styleClass="stat-value"/>
                                <Label text=" OPEN" styleClass="label-subtle" style="-fx-text-fill: #3B82F6;">
                                    <graphic>
                                        <javafx.scene.shape.SVGPath content="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z" fill="#3B82F6" scaleX="0.75" scaleY="0.75"/>
                                    </graphic>
                                </Label>
                            </VBox>
                            <!-- Card 3 (Admin only) -->
                            <VBox fx:id="sellerCardPending" styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                                <Label text="Chờ duyệt" styleClass="stat-label"/>
                                <Label text="0" styleClass="stat-value"/>
                                <Label text=" PENDING" styleClass="label-subtle" style="-fx-text-fill: #F59E0B;">
                                    <graphic>
                                        <javafx.scene.shape.SVGPath content="M6 2v6h.01L6 8.01 10 12l-4 4 .01.01H6V22h12v-5.99h-.01L18 16l-4-4 4-3.99-.01-.01H18V2H6zm10 14.5V20H8v-3.5l4-4 4 4zm-4-5l-4-4V4h8v3.5l-4 4z" fill="#F59E0B" scaleX="0.65" scaleY="0.65"/>
                                    </graphic>
                                </Label>
                            </VBox>
                            <!-- Card 4 (Admin only) -->
                            <VBox fx:id="sellerCardTotalAuctions" styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                                <Label text="Tổng phiên" styleClass="stat-label"/>
                                <Label text="0" styleClass="stat-value"/>
                                <Label text=" Tất cả trạng thái" styleClass="label-subtle" style="-fx-text-fill: #8B5CF6;">
                                    <graphic>
                                        <javafx.scene.shape.SVGPath content="M11.99 18.54l-7.37-5.73L3 14.07l9 7 9-7-1.63-1.27zM12 16l7.36-5.73L21 9l-9-7-9 7 1.63 1.27L12 16zm0-11.47L17.74 9 12 13.47 6.26 9 12 4.53z" fill="#8B5CF6" scaleX="0.7" scaleY="0.7"/>
                                    </graphic>
                                </Label>
                            </VBox>
                            <!-- Card 5 (Admin only) -->
                            <VBox fx:id="sellerCardTotalUsers" styleClass="stat-card" spacing="8" HBox.hgrow="ALWAYS">
                                <Label text="Người dùng" styleClass="stat-label"/>
                                <Label text="0" styleClass="stat-value"/>
                                <Label text=" Bidder + Seller + Admin" styleClass="label-subtle" style="-fx-text-fill: #06B6D4;">
                                    <graphic>
                                        <javafx.scene.shape.SVGPath content="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z" fill="#06B6D4" scaleX="0.75" scaleY="0.75"/>
                                    </graphic>
                                </Label>
                            </VBox>
                        </HBox>

                        <!-- Main Content: 70% Left (Hot Items) + 30% Right (Stats & Pie) -->
                        <HBox spacing="20" alignment="TOP_LEFT" VBox.vgrow="ALWAYS">
                            <!-- LEFT 70%: Top Sản phẩm Nổi bật -->
                            <VBox spacing="12" HBox.hgrow="ALWAYS" prefWidth="70" VBox.vgrow="ALWAYS" styleClass="card">
                                <Label text=" Top Sản phẩm Nổi bật" styleClass="section-title">
                                    <graphic>
                                        <javafx.scene.shape.SVGPath content="M17.66 11.2c-.23-.3-.51-.56-.77-.82-.67-.6-1.43-1.03-2.07-1.66C13.33 7.26 13 4.85 13.95 3c-.95.23-1.78.75-2.49 1.32-2.59 2.08-3.61 5.75-2.39 8.9.04.1.08.2.08.33 0 .22-.15.42-.35.5-.22.1-.46.04-.64-.12a6.35 6.35 0 0 1-1.68-2.19c-.5-1.13-.53-2.39-.23-3.56C4.1 10.15 3 13.62 3.65 16.71c.54 2.58 2.34 4.8 4.78 5.74 2.82 1.09 6.27.53 8.44-1.6 2.39-2.34 2.94-6.07.79-9.65zm-4.7 7.02c-1.34 1.15-3.32 1.16-4.4-.13-.26-.31-.47-.65-.63-1.02.5.47 1.19.78 1.93.78 1.54 0 2.8-1.25 2.8-2.8 0-.46-.11-.9-.31-1.28.67.62 1.18 1.48 1.36 2.45.1.53-.02 1.09-.35 1.5l-.4.5z" fill="#F97316" scaleX="0.8" scaleY="0.8"/>
                                    </graphic>
                                </Label>
                                <ScrollPane fitToWidth="true" vbarPolicy="AS_NEEDED" hbarPolicy="NEVER" styleClass="scroll-pane" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                                    <FlowPane fx:id="sellerHotItemsBox" hgap="20" vgap="20" style="-fx-padding: 8 4 16 4;"/>
                                </ScrollPane>
                            </VBox>

                            <!-- RIGHT 30%: Stats & Pie Chart (stacked vertically) -->
                            <VBox spacing="20" prefWidth="30" VBox.vgrow="ALWAYS">
                                <!-- CARD 1: Stats & Heatmap -->
                                <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="12" alignment="TOP_LEFT">
                                    <Label text="Thống kê doanh thu" styleClass="section-title"/>

                                    <VBox spacing="8">
                                        <Label text="Tổng doanh thu" styleClass="label-subtle"/>
                                        <Label fx:id="sellerEarningLabel" text="0 ₫" styleClass="stat-value"/>
                                    </VBox>

                                    <VBox spacing="8">
                                        <Label text="Doanh thu 30 ngày" styleClass="label-subtle"/>
                                        <Label fx:id="sellerRevenueLabel" text="0 ₫" styleClass="stat-value"/>
                                    </VBox>

                                    <VBox spacing="8" VBox.vgrow="ALWAYS">
                                        <Label text="Doanh thu 35 ngày gần nhất" styleClass="label-subtle"/>
                                        <GridPane fx:id="sellerRevenueHeatmap" hgap="3" vgap="3" alignment="TOP_LEFT">
                                            <Label text="Sun" styleClass="heatmap-day-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                            <Label text="Mon" styleClass="heatmap-day-label" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                                            <Label text="Tue" styleClass="heatmap-day-label" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                                            <Label text="Wed" styleClass="heatmap-day-label" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
                                            <Label text="Thu" styleClass="heatmap-day-label" GridPane.columnIndex="4" GridPane.rowIndex="0"/>
                                            <Label text="Fri" styleClass="heatmap-day-label" GridPane.columnIndex="5" GridPane.rowIndex="0"/>
                                            <Label text="Sat" styleClass="heatmap-day-label" GridPane.columnIndex="6" GridPane.rowIndex="0"/>
                                        </GridPane>
                                    </VBox>
                                </VBox>

                                <!-- CARD 2: Pie Chart -->
                                <VBox styleClass="card" VBox.vgrow="ALWAYS" spacing="12" alignment="TOP_CENTER">
                                    <Label text="Phân bố danh mục đã bán" styleClass="section-title"/>
                                    <StackPane VBox.vgrow="ALWAYS" alignment="CENTER">
                                        <PieChart fx:id="sellerCategoryPieChart" legendVisible="false"/>
                                    </StackPane>
                                    <FlowPane fx:id="sellerPieLegend" hgap="10" vgap="6" alignment="CENTER"/>
                                </VBox>
                            </VBox>
                        </HBox>
                    </VBox>

                </VBox>
            </ScrollPane>
        </StackPane>
    </center>

</BorderPane>
