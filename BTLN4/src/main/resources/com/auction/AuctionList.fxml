<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/21"
            fx:controller="com.auction.controller.AuctionListController"
            stylesheets="@styles/main.css"
            styleClass="main-container">

    <left>
        <fx:include source="components/Sidebar.fxml" fx:id="sidebar"/>
    </left>

    <center>
        <StackPane pickOnBounds="false">
            <!-- Aesthetic Geometric Background -->
            <Pane style="-fx-background-color: transparent;" mouseTransparent="true">
                <javafx.scene.shape.Circle radius="200" centerX="800" centerY="50" styleClass="geo-shape-1" />
                <javafx.scene.shape.Circle radius="300" centerX="150" centerY="600" styleClass="geo-shape-2" />
                <javafx.scene.shape.Polygon points="600,600, 800,400, 1000,600" styleClass="geo-shape-3" />
            </Pane>
            
            <VBox styleClass="content-area" style="-fx-background-color: transparent;" spacing="16" fillWidth="true">

            <!-- Desktop Header: Clock + Notification Bell -->
            <fx:include source="components/DesktopHeader.fxml" fx:id="desktopHeader"/>

            <!-- Header row -->
            <HBox alignment="CENTER_LEFT" spacing="12">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Danh sách Đấu giá" styleClass="page-title"/>
                    <Label text="Tìm kiếm và tham gia các phiên đấu giá" styleClass="label-subtle"/>
                </VBox>
            </HBox>

            <!-- Filters toolbar -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Tìm kiếm sản phẩm..."
                           styleClass="text-field" prefWidth="260" prefHeight="36"/>
                <ComboBox fx:id="statusFilter" promptText="Trạng thái"
                          styleClass="combo-box" prefWidth="150" prefHeight="36"/>
                <ComboBox fx:id="categoryFilter" promptText="Danh mục"
                          styleClass="combo-box" prefWidth="150" prefHeight="36"/>
                <Button fx:id="searchButton" text="Tìm kiếm" onAction="#handleSearch" styleClass="btn-primary" prefHeight="36"/>
                <Button fx:id="resetButton" text="Đặt lại"  onAction="#handleReset"  styleClass="btn-secondary" prefHeight="36"/>
            </HBox>

            <!-- Table -->
            <TableView fx:id="auctionTable" VBox.vgrow="ALWAYS"
                       style="-fx-border-width:0; -fx-background-color:transparent; -fx-padding: 0;"
                       onMouseClicked="#handleRowClick">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
                <columns>
                        <TableColumn fx:id="colTitle"    text="Tên sản phẩm"  prefWidth="220"/>
                        <TableColumn fx:id="colCategory" text="Danh mục"      prefWidth="130"/>
                        <TableColumn fx:id="colStatus"   text="Trạng thái"    prefWidth="120"/>
                        <TableColumn fx:id="colPrice"    text="Giá hiện tại"  prefWidth="130"/>
                        <TableColumn fx:id="colEndTime"  text="Kết thúc lúc"  prefWidth="160"/>
                    </columns>
                    <placeholder>
                        <Label text="Không có phiên đấu giá nào." styleClass="label-subtle"/>
                    </placeholder>
                </TableView>

            <!-- Bottom status bar -->
            <HBox alignment="CENTER_LEFT">
                <Label fx:id="statusLabel" text="" styleClass="label-subtle"/>
            </HBox>

            <HBox fx:id="paginationBox" alignment="CENTER" spacing="6" styleClass="pagination-bar"/>

        </VBox>
        </StackPane>
    </center>

</BorderPane>
