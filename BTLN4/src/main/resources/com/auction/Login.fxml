<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane fx:id="rootPane"
           xmlns:fx="http://javafx.com/fxml/1"
           xmlns="http://javafx.com/javafx/21"
           fx:controller="com.auction.ui.controller.LoginController"
           styleClass="auth-container"
           stylesheets="@styles/main.css"
           style="-fx-padding: 0;">

    <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color:transparent;">
        <VBox alignment="CENTER" fillWidth="true" style="-fx-padding:40 0 40 0;">
            <VBox alignment="CENTER" spacing="0" maxWidth="440" fillWidth="true"
                  styleClass="auth-card">

        <!-- Header & Branding -->
        <VBox alignment="CENTER" spacing="12">
            <ImageView fitWidth="100" fitHeight="100" preserveRatio="true" smooth="true">
                <image>
                    <Image url="@images/logo.png"/>
                </image>
            </ImageView>
            <Label text="Đấu Giá Trực Tuyến" styleClass="auth-title"/>
            <Label text="Đăng nhập để tiếp tục" styleClass="auth-subtitle"/>
        </VBox>

        <Region VBox.vgrow="NEVER" prefHeight="28"/>

        <!-- Form -->
        <VBox spacing="6">
            <Label text="Tên đăng nhập" styleClass="form-label"/>
            <TextField fx:id="usernameField" promptText="Nhập tên đăng nhập"
                       styleClass="text-field" maxWidth="Infinity"/>
        </VBox>

        <Region prefHeight="14"/>

        <VBox spacing="6">
            <Label text="Mật khẩu" styleClass="form-label"/>
            <PasswordField fx:id="passwordField" promptText="Nhập mật khẩu"
                           styleClass="password-field" maxWidth="Infinity"/>
        </VBox>

        <Region prefHeight="6"/>
        <Label fx:id="errorLabel" text="" styleClass="label-error" wrapText="true"/>

        <Region prefHeight="18"/>

        <!-- Login button -->
        <Button fx:id="loginButton" text="Đăng nhập" onAction="#handleLogin"
                styleClass="btn-primary" maxWidth="Infinity"
                defaultButton="true"/>

        <Region prefHeight="14"/>

        <!-- Register link -->
        <HBox alignment="CENTER" spacing="4">
            <Label text="Chưa có tài khoản?" styleClass="label-subtle"/>
            <Button text="Đăng ký ngay" onAction="#handleGoToRegister"
                    styleClass="btn-link"/>
        </HBox>
    </VBox>
        </VBox>
    </ScrollPane>
</StackPane>
