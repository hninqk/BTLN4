<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="369.0" prefWidth="382.0" spacing="12" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="com.auction.controller.LoginController">

    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <Label text="Login System" />

    <TextField fx:id="usernameField" promptText="Username" />

    <PasswordField fx:id="passwordField" promptText="Password" />

    <Button onAction="#handleLogin" text="Login" />

    <Label fx:id="messageLabel" />

</VBox>
