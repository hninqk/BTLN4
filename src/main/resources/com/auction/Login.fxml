<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="10" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="com.auction.controller.LoginController">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <Label text="Đăng nhập hệ thống" />
    <TextField fx:id="usernameField" promptText="Tên đăng nhập" />
    <PasswordField fx:id="passwordField" promptText="Mật khẩu" />
    <Button onAction="#handleLogin" text="Đăng nhập" />
</VBox>
